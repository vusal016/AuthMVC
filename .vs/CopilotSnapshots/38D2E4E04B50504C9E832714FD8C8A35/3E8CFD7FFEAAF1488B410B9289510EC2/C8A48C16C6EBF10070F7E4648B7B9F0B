@{
    ViewData["Title"] = "Home Page";
}
<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MyShop - Home</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
          font-family: 'Segoe UI', sans-serif;
          background: #f4f6fc;
          color: #333;
        }

        .site-header {
          background: #fff;
          border-bottom: 1px solid #e3e6f0;
          padding: 0 2rem;
          display: flex;
          align-items: center;
          justify-content: space-between;
          height: 60px;
          position: sticky;
          top: 0;
          z-index: 10;
        }

        .logo {
          font-size: 18px;
          font-weight: 600;
          color: #333;
          text-decoration: none;
        }

        .nav-links {
          display: flex;
          align-items: center;
          gap: 8px;
        }

        .nav-links a {
          font-size: 14px;
          color: #555;
          text-decoration: none;
          padding: 6px 16px;
          border-radius: 6px;
          border: 1px solid transparent;
          transition: all 0.15s;
        }

        .nav-links a:hover {
          background: #f0f2f8;
          color: #333;
        }

        .btn-outline {
          border-color: #d1d3e2 !important;
          color: #555 !important;
        }

        .btn-primary {
          background: #4e73df !important;
          color: #fff !important;
          border-color: #4e73df !important;
        }

        .btn-primary:hover {
          background: #3a5dc8 !important;
        }

        .btn-logout {
          border-color: #d1d3e2 !important;
          color: #e74a3b !important;
        }

        .main-content {
          max-width: 1140px;
          margin: 2rem auto;
          padding: 0 1.5rem;
        }

        .section-title {
          font-size: 22px;
          font-weight: 600;
          color: #333;
          margin-bottom: 1.5rem;
        }

        .products-grid {
          display: grid;
          grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
          gap: 20px;
        }

        .product-card {
          background: #fff;
          border: 1px solid #e3e6f0;
          border-radius: 12px;
          overflow: hidden;
          transition: border-color 0.15s, box-shadow 0.15s;
        }

        .product-card:hover {
          border-color: #b0bce8;
          box-shadow: 0 4px 12px rgba(78,115,223,0.1);
        }

        .product-img {
          width: 100%;
          height: 180px;
          background: #f0f2f8;
          display: flex;
          align-items: center;
          justify-content: center;
          font-size: 13px;
          color: #aaa;
          overflow: hidden;
        }

        .product-img img {
          width: 100%;
          height: 100%;
          object-fit: cover;
        }

        .product-body {
          padding: 1rem 1.25rem;
        }

        .product-name {
          font-size: 15px;
          font-weight: 600;
          color: #333;
          margin-bottom: 6px;
        }

        .product-price {
          font-size: 16px;
          font-weight: 600;
          color: #4e73df;
          margin-bottom: 14px;
        }

        .product-btn {
          display: block;
          width: 100%;
          padding: 9px 0;
          background: #4e73df;
          color: #fff;
          border: none;
          border-radius: 6px;
          font-size: 14px;
          font-weight: 500;
          cursor: pointer;
          text-align: center;
          transition: opacity 0.15s;
        }

        .product-btn:hover {
          opacity: 0.88;
        }

        .footer {
          text-align: center;
          padding: 2rem;
          font-size: 13px;
          color: #aaa;
          border-top: 1px solid #e3e6f0;
          margin-top: 3rem;
          background: #fff;
        }
    </style>
</head>
<body>

    <header class="site-header">
        <a class="logo" href="index.html">MyShop</a>
        <nav class="nav-links">
            <a href="login.html" class="btn-outline">Login</a>
            <a href="register.html" class="btn-primary">Register</a>
            <a href="logout" class="btn-logout">Logout</a>
        </nav>
    </header>

    <main class="main-content">
        <h1 class="section-title">Products</h1>
        <div class="products-grid">

            <!-- Product Card -->
            <div class="product-card">
                <div class="product-img">
                    <img src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=400&q=80" alt="Watch" onerror="this.parentElement.textContent='No image'">
                </div>
                <div class="product-body">
                    <p class="product-name">Classic Watch</p>
                    <p class="product-price">$49.99</p>
                    <button class="product-btn">Buy Now</button>
                </div>
            </div>

            <!-- Product Card -->
            <div class="product-card">
                <div class="product-img">
                    <img src="https://images.unsplash.com/photo-1585386959984-a4155224a1ad?w=400&q=80" alt="Perfume" onerror="this.parentElement.textContent='No image'">
                </div>
                <div class="product-body">
                    <p class="product-name">Luxury Perfume</p>
                    <p class="product-price">$89.00</p>
                    <button class="product-btn">Add to Cart</button>
                </div>
            </div>

            <!-- Product Card -->
            <div class="product-card">
                <div class="product-img">
                    <img src="https://images.unsplash.com/photo-1491553895911-0055eca6402d?w=400&q=80" alt="Shoes" onerror="this.parentElement.textContent='No image'">
                </div>
                <div class="product-body">
                    <p class="product-name">Sport Shoes</p>
                    <p class="product-price">$120.00</p>
                    <button class="product-btn">Shop Now</button>
                </div>
            </div>

            <!-- Product Card -->
            <div class="product-card">
                <div class="product-img">
                    <img src="https://images.unsplash.com/photo-1526170375885-4d8ecf77b99f?w=400&q=80" alt="Camera" onerror="this.parentElement.textContent='No image'">
                </div>
                <div class="product-body">
                    <p class="product-name">Instant Camera</p>
                    <p class="product-price">$65.50</p>
                    <button class="product-btn">Buy Now</button>
                </div>
            </div>

        </div>
    </main>

    <footer class="footer">
        <span>Copyright &copy; 2025 MyShop. All rights reserved.</span>
    </footer>

</body>
</html>
